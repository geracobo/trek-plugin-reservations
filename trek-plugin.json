{
  "id": "reservations",
  "name": "Reservations",
  "version": "1.0.0",
  "apiVersion": 1,
  "author": "geracobo",
  "description": "Enhanced reservation views for transportation and bookings",
  "icon": "BookMarked",
  "type": "trip-page",
  "trek": ">=3.2.1 <4.0.0",
  "nativeModules": false,
  "permissions": [
    "db:read:trips",
    "db:read:files",
    "db:read:costs",
    "db:write:reservations",
    "db:write:accommodations",
    "db:write:places",
    "db:write:files",
    "db:write:costs",
    "http:outbound:nominatim.openstreetmap.org",
    "http:outbound:places.googleapis.com"
  ],
  "egress": ["nominatim.openstreetmap.org", "places.googleapis.com"],
  "settings": [
    {
      "key": "googlePlacesApiKey",
      "label": "Google Places API key",
      "input_type": "text",
      "secret": true,
      "scope": "instance",
      "hint": "Optional. Enables Google Places search; OpenStreetMap remains the fallback when it is unset."
    }
  ],
  "capabilities": {
    "tripPage": {
      "position": 1
    }
  },
  "requiredAddons": [],
  "pluginDependencies": [],
  "routes": [
    {
      "method": "GET",
      "path": "/reservations",
      "auth": true
    }
  ]
}
