  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tailwindcss": "^4.3.2",
    "trek-plugin-sdk": "^1.4.1",
    "typescript": "^5.7.2"
  }
